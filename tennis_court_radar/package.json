{
  "name": "tennis-court-radar",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --minify && esbuild src/frontend/app.tsx --bundle --platform=browser --format=iife --outfile=public/app.js --minify --sourcemap --jsx=automatic --jsx-import-source=react",
    "build:dev": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs && esbuild src/frontend/app.tsx --bundle --platform=browser --format=iife --outfile=public/app.js --jsx=automatic --jsx-import-source=react --sourcemap",
    "dev": "npm run build:dev && APP_DIR=. DATA_DIR=./data node dist/bundle.cjs",
    "start": "node dist/bundle.cjs"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@mantine/core": "^7.0.0",
    "@mantine/hooks": "^7.0.0",
    "cheerio": "^1.1.0",
    "fastify": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.dev.wixpress.com/"
  }
}
